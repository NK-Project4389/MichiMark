{
  "model": "sonnet",
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(dart analyze*)",
      "Bash(dart run build_runner*)",
      "Bash(flutter build*)",
      "Bash(flutter test*)",
      "Bash(flutter run*)",
      "Bash(flutter pub*)",
      "Bash(cd flutter && flutter *)",
      "Bash(pod install*)",
      "Bash(xcodebuild *)",
      "Bash(open *)",
      "Bash(ls*)",
      "Bash(mkdir*)",
      "Bash(xcrun *)",
      "Bash(sqlite3 *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/kurosakinobuyuki/ClaudeCode/App/MichiMark/.claude/hooks/on_push.sh"
          }
        ]
      }
    ]
  }
}
